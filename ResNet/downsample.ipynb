   "source": [
    "def forward(self, x):\n",
    "    i=x\n",
    "    x=self.conv1(x)\n",
    "    x=self.bn1(x)\n",
    "    x=self.relu(x)\n",
    "\n",
    "    x=self.conv2(x)\n",
    "    x=self.bn2(x)\n",
    "\n",
    "    if self.downsample is not None:\n",
    "        i = self.downsample(i) # 다운샘플 적용 \n",
    "\n",
    "    x += i\n",
    "    x=self.relu(x)\n",
    "    return x"
   ]
  }
