   "source": [
    "def forward(self,x):\n",
    "    i = x # 나중에 더해줘야 하므로 저장\n",
    "    x=self.conv1(x)\n",
    "    x=self.bn1(x) # 값의 범위를 항상 일정하게 유지(모든 conv에)\n",
    "    x=self.relu(x)\n",
    "\n",
    "    x=self.conv2(x)\n",
    "    x=self.bn2(x)\n",
    "\n",
    "    x+=i # 원본 + conv 이후 -> 이후 ReLU 적용 \n",
    "    x=self.relu(x)\n",
    "    return x\n"
   ]
  }
